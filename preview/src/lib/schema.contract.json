{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PreviewContract",
  "type": "object",
  "$defs": {
    "BatchPushStatus": {
      "enum": [
        "not-pushed",
        "pushed"
      ],
      "type": "string",
      "title": "BatchPushStatus"
    },
    "CardBatch": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "1",
          "default": "1",
          "type": "string"
        },
        "metadata": {
          "$ref": "#/$defs/LessonMetadata"
        },
        "notes": {
          "items": {
            "$ref": "#/$defs/GeneratedNote"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": [
        "metadata",
        "notes"
      ],
      "type": "object",
      "title": "CardBatch"
    },
    "CardPreview": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "item_id": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "recognition",
            "production",
            "listening",
            "number-context",
            "read-aloud",
            "chunked-reading",
            "decodable-passage"
          ],
          "type": "string"
        },
        "front_html": {
          "type": "string"
        },
        "back_html": {
          "type": "string"
        },
        "audio_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "image_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "approved": {
          "default": true,
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "item_id",
        "kind",
        "front_html",
        "back_html"
      ],
      "type": "object",
      "title": "CardPreview"
    },
    "DashboardBatch": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "topic": {
          "type": "string"
        },
        "lesson_date": {
          "format": "date",
          "type": "string"
        },
        "target_deck": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "notes": {
          "type": "integer"
        },
        "cards": {
          "type": "integer"
        },
        "approved_notes": {
          "type": "integer"
        },
        "approved_cards": {
          "type": "integer"
        },
        "audio_notes": {
          "type": "integer"
        },
        "image_notes": {
          "type": "integer"
        },
        "exact_duplicates": {
          "type": "integer"
        },
        "near_duplicates": {
          "type": "integer"
        },
        "push_status": {
          "default": "not-pushed",
          "enum": [
            "not-pushed",
            "pushed"
          ],
          "type": "string"
        },
        "media_hydrated": {
          "default": false,
          "type": "boolean"
        },
        "synced_batch_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "lanes": {
          "items": {
            "enum": [
              "lesson",
              "new-vocab",
              "reading-speed",
              "grammar",
              "listening"
            ],
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "path",
        "title",
        "topic",
        "lesson_date",
        "notes",
        "cards",
        "approved_notes",
        "approved_cards",
        "audio_notes",
        "image_notes",
        "exact_duplicates",
        "near_duplicates"
      ],
      "type": "object",
      "title": "DashboardBatch"
    },
    "DashboardLessonContext": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      },
      "required": [
        "path",
        "label"
      ],
      "type": "object",
      "title": "DashboardLessonContext"
    },
    "DashboardResponse": {
      "additionalProperties": false,
      "properties": {
        "status": {
          "$ref": "#/$defs/ServiceStatus"
        },
        "stats": {
          "$ref": "#/$defs/DashboardStats"
        },
        "recent_batches": {
          "items": {
            "$ref": "#/$defs/DashboardBatch"
          },
          "type": "array"
        },
        "lesson_contexts": {
          "items": {
            "$ref": "#/$defs/DashboardLessonContext"
          },
          "type": "array"
        },
        "syncable_files": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "status",
        "stats"
      ],
      "type": "object",
      "title": "DashboardResponse"
    },
    "DashboardStats": {
      "additionalProperties": false,
      "properties": {
        "local_batch_count": {
          "default": 0,
          "type": "integer"
        },
        "local_note_count": {
          "default": 0,
          "type": "integer"
        },
        "local_card_count": {
          "default": 0,
          "type": "integer"
        },
        "pending_push_count": {
          "default": 0,
          "type": "integer"
        },
        "audio_note_count": {
          "default": 0,
          "type": "integer"
        },
        "image_note_count": {
          "default": 0,
          "type": "integer"
        },
        "lane_counts": {
          "additionalProperties": {
            "type": "integer"
          },
          "type": "object"
        },
        "anki_note_count": {
          "default": 0,
          "type": "integer"
        },
        "anki_card_count": {
          "default": 0,
          "type": "integer"
        },
        "anki_deck_counts": {
          "additionalProperties": {
            "type": "integer"
          },
          "type": "object"
        }
      },
      "type": "object",
      "title": "DashboardStats"
    },
    "DeleteBatchResult": {
      "additionalProperties": false,
      "properties": {
        "deleted_paths": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "deleted_media_paths": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object",
      "title": "DeleteBatchResult"
    },
    "DuplicateNote": {
      "additionalProperties": false,
      "properties": {
        "item_id": {
          "type": "string"
        },
        "korean": {
          "type": "string"
        },
        "english": {
          "type": "string"
        },
        "existing_note_id": {
          "type": "integer"
        }
      },
      "required": [
        "item_id",
        "korean",
        "english",
        "existing_note_id"
      ],
      "type": "object",
      "title": "DuplicateNote"
    },
    "ExampleSentence": {
      "additionalProperties": false,
      "properties": {
        "korean": {
          "type": "string"
        },
        "english": {
          "type": "string"
        }
      },
      "required": [
        "korean",
        "english"
      ],
      "type": "object",
      "title": "ExampleSentence"
    },
    "GeneratedNote": {
      "additionalProperties": false,
      "properties": {
        "item": {
          "$ref": "#/$defs/LessonItem"
        },
        "cards": {
          "items": {
            "$ref": "#/$defs/CardPreview"
          },
          "minItems": 1,
          "type": "array"
        },
        "approved": {
          "default": true,
          "type": "boolean"
        },
        "note_key": {
          "default": "",
          "type": "string"
        },
        "lane": {
          "default": "lesson",
          "enum": [
            "lesson",
            "new-vocab",
            "reading-speed",
            "grammar",
            "listening"
          ],
          "type": "string"
        },
        "skill_tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "duplicate_status": {
          "default": "new",
          "enum": [
            "new",
            "exact-duplicate",
            "near-duplicate"
          ],
          "type": "string"
        },
        "duplicate_note_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "duplicate_note_id": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "duplicate_source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "inclusion_reason": {
          "default": "New card",
          "type": "string"
        }
      },
      "required": [
        "item",
        "cards"
      ],
      "type": "object",
      "title": "GeneratedNote"
    },
    "JobKind": {
      "enum": [
        "lesson-generate",
        "new-vocab",
        "sync-media"
      ],
      "type": "string",
      "title": "JobKind"
    },
    "JobResponse": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "lesson-generate",
            "new-vocab",
            "sync-media"
          ],
          "type": "string"
        },
        "status": {
          "enum": [
            "queued",
            "running",
            "succeeded",
            "failed"
          ],
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "type": "string"
        },
        "updated_at": {
          "format": "date-time",
          "type": "string"
        },
        "progress_current": {
          "default": 0,
          "type": "integer"
        },
        "progress_total": {
          "default": 0,
          "type": "integer"
        },
        "progress_label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "logs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "output_paths": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "id",
        "kind",
        "status",
        "created_at",
        "updated_at"
      ],
      "type": "object",
      "title": "JobResponse"
    },
    "JobStatus": {
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed"
      ],
      "type": "string",
      "title": "JobStatus"
    },
    "LessonItem": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "lesson_id": {
          "type": "string"
        },
        "item_type": {
          "enum": [
            "vocab",
            "phrase",
            "grammar",
            "dialogue",
            "number"
          ],
          "type": "string"
        },
        "korean": {
          "type": "string"
        },
        "english": {
          "type": "string"
        },
        "pronunciation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "examples": {
          "items": {
            "$ref": "#/$defs/ExampleSentence"
          },
          "type": "array"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "lane": {
          "default": "lesson",
          "enum": [
            "lesson",
            "new-vocab",
            "reading-speed",
            "grammar",
            "listening"
          ],
          "type": "string"
        },
        "skill_tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "source_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "image_prompt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "audio": {
          "anyOf": [
            {
              "$ref": "#/$defs/MediaAsset"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "image": {
          "anyOf": [
            {
              "$ref": "#/$defs/MediaAsset"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "id",
        "lesson_id",
        "item_type",
        "korean",
        "english"
      ],
      "type": "object",
      "title": "LessonItem"
    },
    "LessonMetadata": {
      "additionalProperties": false,
      "properties": {
        "lesson_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "topic": {
          "type": "string"
        },
        "lesson_date": {
          "format": "date",
          "type": "string"
        },
        "source_description": {
          "type": "string"
        },
        "target_deck": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "lesson_id",
        "title",
        "topic",
        "lesson_date",
        "source_description"
      ],
      "type": "object",
      "title": "LessonMetadata"
    },
    "MediaAsset": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string"
        },
        "prompt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "source_url": {
          "anyOf": [
            {
              "format": "uri",
              "maxLength": 2083,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "path"
      ],
      "type": "object",
      "title": "MediaAsset"
    },
    "PushResult": {
      "additionalProperties": false,
      "properties": {
        "deck_name": {
          "type": "string"
        },
        "approved_notes": {
          "type": "integer"
        },
        "approved_cards": {
          "type": "integer"
        },
        "duplicate_notes": {
          "items": {
            "$ref": "#/$defs/DuplicateNote"
          },
          "type": "array"
        },
        "dry_run": {
          "type": "boolean"
        },
        "can_push": {
          "type": "boolean"
        },
        "notes_added": {
          "default": 0,
          "type": "integer"
        },
        "cards_created": {
          "default": 0,
          "type": "integer"
        },
        "pushed_note_ids": {
          "items": {
            "type": "integer"
          },
          "type": "array"
        },
        "sync_requested": {
          "default": false,
          "type": "boolean"
        },
        "sync_completed": {
          "default": false,
          "type": "boolean"
        },
        "reviewed_batch_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "deck_name",
        "approved_notes",
        "approved_cards",
        "dry_run",
        "can_push"
      ],
      "type": "object",
      "title": "PushResult"
    },
    "ServiceStatus": {
      "additionalProperties": false,
      "properties": {
        "backend_ok": {
          "default": true,
          "type": "boolean"
        },
        "anki_connect_ok": {
          "default": false,
          "type": "boolean"
        },
        "anki_connect_version": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "openai_configured": {
          "default": false,
          "type": "boolean"
        }
      },
      "type": "object",
      "title": "ServiceStatus"
    },
    "StudyLane": {
      "enum": [
        "lesson",
        "new-vocab",
        "reading-speed",
        "grammar",
        "listening"
      ],
      "type": "string",
      "title": "StudyLane"
    }
  }
}
