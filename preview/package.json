{
  "name": "korean-anki-preview",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:schema:contract": "PYTHONPATH=../src ../.venv/bin/python -m korean_anki.schema_codegen --write src/lib/schema.contract.json",
    "generate:schema": "pnpm run generate:schema:contract && node scripts/generate-schema-types.mjs src/lib/schema.contract.json src/lib/schema.ts",
    "dev": "pnpm run generate:schema && vite",
    "build": "pnpm run generate:schema && tsc -b && vite build",
    "preview": "vite preview",
    "test:e2e": "pnpm run generate:schema && playwright test",
    "test:e2e:headed": "pnpm run generate:schema && playwright test --headed"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.475.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "json-schema-to-typescript": "15.0.4",
    "playwright": "^1.58.2",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  },
  "packageManager": "pnpm@10.26.2+sha512.0e308ff2005fc7410366f154f625f6631ab2b16b1d2e70238444dd6ae9d630a8482d92a451144debc492416896ed16f7b114a86ec68b8404b2443869e68ffda6"
}
